{
	"name": "sokos-astro-template",
	"type": "module",
	"version": "1.0.0",
	"scripts": {
		"astro": "astro",
		"dev": "astro dev",
		"dev:mock": "concurrently \"pnpm dev\" \"tsx mock/server.ts\"",
		"build": "astro check && astro build",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"prettier:format": "prettier --write '**/*.astro'",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/node": "10.0.6",
		"@astrojs/react": "5.0.4",
		"@navikt/aksel-icons": "7.37.0",
		"@navikt/ds-css": "7.37.0",
		"@navikt/ds-react": "7.37.0",
		"@navikt/oasis": "4.1.4",
		"astro": "6.2.2",
		"pino-http": "11.0.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"rollup-plugin-import-map": "3.0.0",
		"zod": "4.4.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@hono/node-server": "1.19.14",
		"@navikt/aksel-stylelint": "7.37.0",
		"@types/node": "25.6.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"concurrently": "9.2.1",
		"hono": "4.12.18",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"postcss": "8.5.12",
		"postcss-prefix-selector": "2.1.1",
		"prettier": "3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"stylelint": "16.26.1",
		"stylelint-config-standard": "39.0.1",
		"tsx": "4.21.0",
		"typescript": "5.9.3"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.astro": "prettier --write",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.0.8",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912"
}
