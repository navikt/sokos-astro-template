{
	"name": "sokos-astro-template",
	"type": "module",
	"version": "1.0.0",
	"scripts": {
		"astro": "astro",
		"dev": "astro dev",
		"dev:mock": "concurrently \"pnpm dev\" \"tsx mock/server.ts\"",
		"build": "astro check && astro build",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"prettier:format": "prettier --write '**/*.astro'",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/node": "10.1.1",
		"@astrojs/react": "5.0.5",
		"@navikt/aksel-icons": "7.37.0",
		"@navikt/ds-css": "7.37.0",
		"@navikt/ds-react": "7.37.0",
		"@navikt/oasis": "4.1.4",
		"astro": "7.1.0",
		"pino-http": "11.0.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"rollup-plugin-import-map": "3.0.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@hono/node-server": "2.0.8",
		"@navikt/aksel-stylelint": "7.37.0",
		"@types/node": "26.1.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"concurrently": "10.0.3",
		"hono": "4.12.30",
		"husky": "9.1.7",
		"lint-staged": "17.0.8",
		"postcss": "8.5.19",
		"postcss-prefix-selector": "2.1.1",
		"prettier": "3.9.5",
		"prettier-plugin-astro": "0.14.1",
		"stylelint": "17.14.0",
		"stylelint-config-standard": "40.0.0",
		"tsx": "4.23.1",
		"typescript": "6.0.3"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.astro": "prettier --write",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.7.0",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
