{
	"name": "sokos-astro-template",
	"type": "module",
	"version": "1.0.0",
	"scripts": {
		"astro": "astro",
		"dev": "astro dev",
		"dev:mock": "concurrently \"pnpm dev\" \"tsx mock/server.ts\"",
		"build": "astro check && astro build",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"prettier:format": "prettier --write '**/*.astro'",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/node": "10.1.1",
		"@astrojs/react": "5.0.5",
		"@navikt/aksel-icons": "7.37.0",
		"@navikt/ds-css": "7.37.0",
		"@navikt/ds-react": "7.37.0",
		"@navikt/oasis": "4.1.4",
		"astro": "6.4.6",
		"pino-http": "11.0.0",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"rollup-plugin-import-map": "3.0.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@hono/node-server": "2.0.2",
		"@navikt/aksel-stylelint": "7.37.0",
		"@types/node": "25.8.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"concurrently": "9.2.1",
		"hono": "4.12.25",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"postcss": "8.5.14",
		"postcss-prefix-selector": "2.1.1",
		"prettier": "3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"stylelint": "16.26.1",
		"stylelint-config-standard": "39.0.1",
		"tsx": "4.22.0",
		"typescript": "6.0.3"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.astro": "prettier --write",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.5.2",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
