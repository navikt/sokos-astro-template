{
	"name": "sokos-astro-template",
	"type": "module",
	"version": "1.0.0",
	"scripts": {
		"astro": "astro",
		"dev": "astro dev",
		"dev:mock": "concurrently \"pnpm dev\" \"tsx mock/server.ts\"",
		"build": "astro check && astro build",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"prettier:format": "prettier --write '**/*.astro'",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/node": "10.1.1",
		"@astrojs/react": "5.0.5",
		"@navikt/aksel-icons": "7.37.0",
		"@navikt/ds-css": "7.37.0",
		"@navikt/ds-react": "7.37.0",
		"@navikt/oasis": "4.1.4",
		"astro": "6.4.6",
		"pino-http": "11.0.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"rollup-plugin-import-map": "3.0.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@hono/node-server": "2.0.6",
		"@navikt/aksel-stylelint": "7.37.0",
		"@types/node": "26.1.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"concurrently": "10.0.3",
		"hono": "4.12.27",
		"husky": "9.1.7",
		"lint-staged": "17.0.8",
		"postcss": "8.5.16",
		"postcss-prefix-selector": "2.1.1",
		"prettier": "3.9.4",
		"prettier-plugin-astro": "0.14.1",
		"stylelint": "17.14.0",
		"stylelint-config-standard": "40.0.0",
		"tsx": "4.22.4",
		"typescript": "6.0.3"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.astro": "prettier --write",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.10.0",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
